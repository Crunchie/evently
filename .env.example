# Copy to .env and fill in. Never commit .env.

# Django secret key. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# 1 for local development, 0 in production.
DEBUG=1

# Comma-separated hostnames the app answers on (prod). e.g. rsvp.evently.example
ALLOWED_HOSTS=localhost,127.0.0.1

# Where SQLite DB + Litestream backups live. Local: ./data ; Docker: /data
DATA_DIR=./data

# IANA timezone for displaying/entering event times (default: UTC).
# e.g. Australia/Sydney, Europe/London
TIME_ZONE=UTC

# --- Email (Resend) — Phase 4+ ---
RESEND_API_KEY=
EMAIL_FROM=Sam & Kate <invites@your-domain>
EMAIL_REPLY_TO=you@personal-inbox

# --- Cloudflare Access (organizer auth) — Phase 2+ ---
# Leave blank in local dev to fall back to normal Django admin login.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# --- Deployment ---
# cloudflared tunnel token (from the Cloudflare Zero Trust dashboard).
TUNNEL_TOKEN=
# Host UID/GID that owns ./data, so the container can read/write it (check with `id`).
PUID=1001
PGID=1001
